<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= render "layouts/head" %>
  </head>
  <body class="font-body">
    <header class="sticky top-0 z-50">
      <%= render "shared/navbar" %>
    </header>

    <main>
      <%= render "shared/flashes" %>
      <section class="page-shell">
        <div class="max-w-md mx-auto mt-12 bg-white/40 backdrop-blur-sm rounded-2xl p-8 flex flex-col gap-6">
          <h1 class="text-h1 font-display text-zinc-900"><%= content_for(:page_title) %></h1>
          <%= yield %>
        </div>
      </section>
    </main>
  </body>
</html>
