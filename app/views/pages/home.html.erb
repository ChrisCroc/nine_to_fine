<section class="min-h-[70vh] flex flex-col items-center justify-center bg-linear-to-tr from-yellow-900 to-yellow-50 shadow-xl/30 p-4 md:p-8 lg:p-12 text-center">
  <%= image_tag "hero.svg", alt: "Nine to Fine", class: "w-full max-w-sm md:max-w-md drop-shadow-lg" %>
  <p class="text-base md:text-lg lg:text-xl font-light text-[#E7DBC4]/85 text-shadow-lg/20 mt-4 italic">Get dressed up, no haste, no hustle.</p>
  <%= link_to "Get started", new_user_registration_path, class: "bg-zinc-900 hover:bg-zinc-700 transition text-base md:text-lg lg:text-xl text-[#E7DBC4] py-2 px-5 md:py-3 md:px-6 rounded-md font-semibold mt-8 shadow-lg/30" %>
</section>
<section class="bg-champagne-light text-zinc-900 px-4 py-12 md:px-8 md:py-16 text-center">
  <h1 class="font-display text-h1 max-w-2xl mx-auto">Get dressed with intention, not in a rush.</h1>
  <p class="font-body text-body text-zinc-700 max-w-xl mx-auto mt-4">
    Nine to Fine turns your wardrobe into something you enjoy using. Catalog what you own, build outfits you love, and get a little help when inspiration runs short - all at a calm, unhurried pace.
  </p>
</section>
<section class="bg-champagne-light px-4 pb-12 md:px-8 md:pb-16">
  <div class="max-w-5xl mx-auto grid grid-cols-1 gap-8 md:grid-cols-3">
    <div class="bg-[#3F3F46] rounded-xl border border-champagne-deep/30 shadow-md p-6 text-center md:text-left">
      <h2 class="font-display text-h3 text-champagne-deep text-center">Your closet, digitzed</h2>
        <p class="font-body text-caption text-champagne-deep mt-2">Add every piece with its category, color, brand and tags. Never forget what you own</p>
    </div>
    <div class="bg-[#3F3F46] rounded-xl border border-champagne-deep/30 shadow-md p-6 text-center md:text-left">
      <h2 class="font-display text-h3 text-champagne-deep text-center">Compose with ease</h2>
      <p class="font-body text-caption text-champagne-deep mt-2">Combine pieces into outfits, save your favorite looks, and revisit them whenever you get dressed.</p>
    </div>
    <div class="bg-[#3F3F46] rounded-xl border border-champagne-deep/30 shadow-md p-6 text-center md:text-left">
      <h2 class="font-display text-h3 text-champagne-deep text-center">An AI stylist, on tap</h2>
      <p class="font-body text-caption text-champagne-deep mt-2">Out of idea? Let the assistant suggest a full outfit built from the clothes you already have</p>
    </div>
  </div>
</section>
