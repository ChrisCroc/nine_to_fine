<%# locals: (taggable:) %>
<div class="mb-6">
  <h2 class="text-xs font-medium uppercase tracking-wide text-zinc-400 mb-2">Tags</h2>
  <% if taggable.tags.any? %>
    <div class="flex flex-wrap gap-2">
      <% taggable.tags.each do |tag| %>
        <%= link_to tag.name, garments_path(q: { tag_id: tag.id }), class: "inline-block bg-zinc-100 text-zinc-700 hover:bg-zinc-200 hover:text-zinc-900 text-sm px-3 py-1 rounded-full transition" %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-zinc-400 italic">No tags assigned</p>
  <% end %>
</div>
