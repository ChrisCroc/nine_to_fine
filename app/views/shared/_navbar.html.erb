<nav class="bg-zinc-800 py-4 px-8 flex items-center justify-between">
  <div class="flex items-center gap-4">
    <%= link_to root_path, class: "shrink-0", aria: { label: "Nine to Fine, accueil" } do %>
      <%= image_tag "icon.svg", alt: "Nine to Fine", class: "h-9 w-9" %>
    <% end %>
    <% if user_signed_in? %>
      <%= link_to "Closet", garments_path, class: "text-champagne hover:text-white text-h2 font-display mx-2" %>
      <%= link_to "Dressing", outfits_path, class: "text-champagne hover:text-white text-h2 font-display" %>
    <% end %>
  </div>
  <div class="flex gap-4">
    <% if user_signed_in? %>
      <span class="text-champagne hover:text-white text-caption"><%= link_to current_user.username, user_path(current_user) %></span>
      <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-champagne hover:text-white text-caption" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "text-champagne hover:text-white text-caption" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "text-champagne hover:text-white text-caption" %>
    <% end %>
  </div>
</nav>
