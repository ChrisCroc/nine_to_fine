<%= link_to user_path(user), data: { turbo_frame: "_top"},
      class: "flex items-center gap-3 px-4 py-3 hover:bg-zinc-50 transition" do %>
  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-champagne text-zinc-900 font-semibold">
    <%= user.username.first.upcase %>
  </span>
  <span class="flex flex-col">
    <span class="font-medium text-zinc-900"><%= user.username %></span>
    <span class="text-xs text-zinc-500"><%= pluralize(user.followers_count, "follower") %></span>
  </span>
<% end %>
