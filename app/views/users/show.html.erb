<section class="page-shell">
  <div class="max-w-md mx-auto mt-12 bg-white/40 backdrop-blur-sm rounded-2xl p-8 flex flex-col items-center gap-4">
    <h1 class="text-h1 font-display text-zinc-900"><%= @user.username %></h1>

    <% if current_user == @user %>
      <%= link_to "Edit profile", edit_user_path(@user), class: "text-caption text-zinc-600 hover:text-zinc-900" %>
      <%= link_to "Account settings", edit_user_registration_path, class: "text-caption text-zinc-600 hover:text-zinc-900" %>
      <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-caption text-zinc-600 hover:text-zinc-900" %>
    <% end %>
    <%= render "users/follow_button", user: @user %>
  </div>

  <div class="max-w-6xl mx-auto mt-10 px-4">
    <% if @outfits.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% @outfits.each do |outfit| %>
          <%= render "outfits/card", outfit: outfit %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <p class="text-lg text-zinc-700">No public outfits yet.</p>
        <% if current_user == @user %>
          <%= link_to "Manage your closet", outfits_path, class: "inline-block mt-3 text-zinc-600 underline hover:text-zinc-900" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
