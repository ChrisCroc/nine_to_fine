<section class="page-shell flex items-center justify-center">
  <div class="w-full max-w-lg bg-white rounded-xl shadow-xl overflow-hidden" data-controller="photo-preview">
    <div class="h-75 bg-zinc-100 flex items-center justify-center">
      <%= render "photo_preview", garment: @garment %>
    </div>
    <div class="p-6 md:p-8">
      <h1 class="text-2xl font-bold text-zinc-900 mb-6">Edit Garment</h1>
      <%= render "form", garment: @garment %>
      <%= link_to "Back to garments", garments_path, class: "block text-center text-sm text-zinc-500 hover:text-zinc-700 mt-4" %>
    </div>
  </div>
</section>
