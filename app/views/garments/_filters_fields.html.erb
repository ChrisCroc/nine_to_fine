<div>
  <h3 class="mb-2 text-sm font-semibold text-zinc-700">Color</h3>
  <div class="flex flex-wrap gap-2">
    <label class="cursor-pointer">
      <input type="radio" name="q[color]" value="" <%= "checked" if current[:color].blank? %> class="peer sr-only">
      <span class="<%= filter_pill_class %>">All</span>
    </label>
    <% @available_colors.each do |color| %>
      <label class="cursor-pointer">
        <input type="radio" name="q[color]" value="<%= color %>" <%= "checked" if current[:color] == color %> class="peer sr-only">
        <span class="<%= filter_pill_class %>"><%= color.capitalize %></span>
      </label>
    <% end %>
  </div>
</div>

<div>
  <h3 class="mb-2 text-sm font-semibold text-zinc-700">Category</h3>
  <div class="flex flex-wrap gap-2">
    <label class="cursor-pointer">
      <input type="radio" name="q[category_id]" value="" <%= "checked" if current[:category_id].blank? %> class="peer sr-only">
      <span class="<%= filter_pill_class %>">All</span>
    </label>
    <% @available_categories.each do |category| %>
      <label class="cursor-pointer">
        <input type="radio" name="q[category_id]" value="<%= category.id %>" <%= "checked" if current[:category_id].to_i == category.id %> class="peer sr-only">
        <span class="<%= filter_pill_class %>"><%= category.name %></span>
      </label>
    <% end %>
  </div>
</div>

<% if @available_brands.any? %>
  <div>
    <h3 class="mb-2 text-sm font-semibold text-zinc-700">Brand</h3>
    <div class="flex flex-wrap gap-2">
      <label class="cursor-pointer">
        <input type="radio" name="q[brand]" value="" <%= "checked" if current[:brand].blank? %> class="peer sr-only">
        <span class="<%= filter_pill_class %>">All</span>
      </label>
      <% @available_brands.each do |brand| %>
        <label class="cursor-pointer">
          <input type="radio" name="q[brand]" value="<%= brand %>" <%= "checked" if current[:brand] == brand %> class="peer sr-only">
          <span class="<%= filter_pill_class %>"><%= brand %></span>
        </label>
      <% end %>
    </div>
  </div>
<% end %>

<% if @available_tags.any? %>
  <div>
    <h3 class="mb-2 text-sm font-semibold text-zinc-700">Tag</h3>
    <div class="flex flex-wrap gap-2">
      <label class="cursor-pointer">
        <input type="radio" name="q[tag_id]" value="" <%= "checked" if current[:tag_id].blank? %> class="peer sr-only">
        <span class="<%= filter_pill_class %>">All</span>
      </label>
      <% @available_tags.each do |tag| %>
        <label class="cursor-pointer">
          <input type="radio" name="q[tag_id]" value="<%= tag.id %>" <%= "checked" if current[:tag_id].to_i == tag.id %> class="peer sr-only">
          <span class="<%= filter_pill_class %>"><%= tag.name %></span>
        </label>
      <% end %>
    </div>
  </div>
<% end %>

<%= hidden_field_tag "q[search]", current[:search] %>
