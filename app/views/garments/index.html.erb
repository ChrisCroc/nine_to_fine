<section class="min-h-screen bg-linear-to-tr from-yellow-900 to-yellow-50 p-4 md:p-8">
    <%# En-tête de page %>
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-champagne text-shadow-lg/30">My Clothes</h1>
      <div class="flex flex-wrap gap-3">
        <%= link_to "Add a piece", new_garment_path, class: "bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition whitespace-nowrap" %>
        <%= link_to "Create an outfit", new_outfit_path, class: "bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition whitespace-nowrap" %>
      </div>
    </div>

    <% if @garments.empty? %>
      <%#  Etat vide %>
      <div class="text-center py-20">
        <p class="text-lg text-zinc-800 mb-4">You haven't added any garments yet.</p>
        <%= link_to "Add your first piece of clothes", new_garment_path, class: "inline-block bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition" %>
      </div>
    <% else %>
      <%# Grille de cards %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @garments.each do |garment| %>
          <%= link_to garment, class: "block bg-white rounded-xl shadow-xl overflow-hidden relative transition duration-300 ease-out hover:scale-105 hover:shadow-2xl hover:z-10" do %>
            <div class="aspect-5/6 bg-white flex items-center justify-center p-3">
              <% if garment.photo.attached? %>
                <%= image_tag garment.photo.variant(resize_to_limit: [ 400, 533 ], format: :webp), class: "h-full w-full object-contain" %>
              <% else %>
                <span class="text-sm text-zinc-400">No photo available</span>
              <% end %>
            </div>
            <div class="p-4">
              <div class="flex items-start justify-between gap-2">
                <h2 class="font-semibold text-zinc-900"><%= garment.name %></h2>
                <span class="shrink-0 inline-block bg-zinc-100 text-zinc-700 text-xs font-medium px-2 py-1 rounded-full"><%= garment.category.name %></span>
              </div>
              <p class="text-sm text-zinc-500 mt-1"><%= garment.color %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
</section>
