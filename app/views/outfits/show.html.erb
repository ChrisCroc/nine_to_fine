<% content_for :page_title, @outfit.name %>

<%= turbo_stream_from @outfit %>

<section class="min-h-screen flex items-center justify-center bg-linear-to-tr from-yellow-900 to-yellow-50 p-4 md:p-8">
  <div class="w-full max-w-6xl md:h-[85vh] bg-white rounded-xl shadow-xl overflow-hidden md:grid md:grid-rows-5">

    <%# Colonne photo (~60%) - futur swipe outfits %>
    <div class="aspect-square w-full md:aspect-auto md:row-span-3">
      <%= render "collage", outfit: @outfit %>
    </div>

    <%# Colonne infos (~40%) %>
    <div class="md:row-span-2 p-6 md:p-8 flex flex-col md:overflow-y-auto">
      <h1 class="text-2xl md:text-3xl font-bold text-zinc-900"><%= @outfit.name %></h1>
      <span class="inline-block self-start bg-zinc-100 text-zinc-700 text-xs font-medium px-3 py-1 rounded-full mt-2 mb-6">Outfit</span>

    <%# Likes %>
    <div class="flex items-center gap-3 mb-6">
      <%= render "outfits/like_button", outfit: @outfit %>
      <%= render "outfits/likes_count", outfit: @outfit %>
    </div>
    
      <dl class="space-y-3 mb-6">
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-zinc-400">Description</dt>
          <dd class="text-zinc-900"><%= @outfit.description.presence || "—" %></dd>
        </div>
      </dl>

      <%# Garments %>
      <div class="mb-6">
        <h2 class="text-xs font-medium uppercase tracking-wide text-zinc-400 mb-2">Garments</h2>
        <% if @outfit.garments.any? %>
          <div class="flex flex-wrap gap-2">
            <% @outfit.garments.each do |garment| %>
              <span class="inline-block bg-zinc-100 text-zinc-700 text-sm px-3 py-1 rounded-full"><%= link_to garment.name, garment %></span>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-zinc-400 italic">No garments added to this outfit yet</p>
        <% end %>
      </div>

      <%# Tags %>
      <%= render "shared/tags", taggable: @outfit %>

      <%# Actions %>
      <div class="flex items-center gap-3 md:mt-auto">
        <%= link_to "Edit", edit_outfit_path(@outfit), class: "flex-1 text-center bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition" %>
        <%= button_to "Delete", outfit_path(@outfit), method: :delete, data: { turbo_confirm: "Are you sure?" }, form_class: "flex-1", class: "w-full text-center bg-white text-red-600 border border-red-300 font-semibold py-2 px-5 rounded-md hover:bg-red-50 transition cursor-pointer" %>
      </div>
      <%= link_to "My Outfits", outfits_path, class: "block text-center text-sm text-zinc-500 hover:text-zinc-700 mt-4" %>
    </div>
  </div>
</section>
