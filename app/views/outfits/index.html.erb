<% content_for :page_title, "My outfits" %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<section class="page-shell">
  <%# Per-user signed stream - the job broadcasts the suggestion here. %>
  <%= turbo_stream_from current_user, :outfit_suggestions %>

  <%# Empty container: the controller respionse injects the modal into it. %>
  <div id="ai_suggestion_modal"></div>
  <div class="mb-8 rounded-xl bg-white/70 p-4 shadow-sm md:p-6">
    <h2 class="mb-2 text-lg font-semibold text-zinc-900">Ask the stylist ✨</h2>
    <%= form_with url: suggestions_path, method: :post,
                  data: { controller: "submit-button reset-form",
                          action: "submit->submit-button#start turbo:submit-end->submit-button#end turbo:submit-end->reset-form#reset" } do |f| %>
      <%= f.text_area :context, rows: 2, required: true,
            placeholder: "e.g. interview in Paris, 13°C and rainy",
            class: "block w-full rounded-md border border-zinc-300 px-3 py-2 text-zinc-900 shadow-sm focus:border-zinc-500 focus:ring-2 focus:ring-zinc-500 focus:outline-none" %>
      <%= f.submit "Compose an outfit",
            data: { "submit-button-target": "button" },
            class: "btn-base mt-3 bg-zinc-900 text-champagne hover:bg-zinc-700 hover:text-white data-loading:cursor-wait data-loading:opacity-50" %>
    <% end %>
  </div>

  <%# En-tête de page %>
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-champagne text-shadow-lg/30">My Outfits</h1>
      <div class="flex flex-wrap gap-3">
      <%= link_to "Create an outfit", new_outfit_path, class: "bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition whitespace-nowrap" %>
      </div>
    </div>

    <% if @outfits.empty? %>

      <%#  Etat vide %>
      <div class="text-center py-20">
        <p class="text-lg text-zinc-800 mb-4">You haven't added any outfits yet.</p>
        <%= link_to "Create your first outfit", new_outfit_path, class: "inline-block bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition" %>
      </div>
      <% else %>

      <%# Grille de cards %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% @outfits.each do |outfit| %>
          <%= link_to outfit, class: "block bg-white rounded-xl shadow-xl overflow-hidden relative transition duration-300 ease-out hover:scale-105 hover:shadow-2xl hover:z-10" do %>
            <div class="h-48">
              <%= render "collage", outfit: outfit %>
            </div>
            <div class="p-4 flex flex-col gap-2">
              <%# ligne nom + tags %>
              <div class="flex items-start justify-between gap-2">
                <h2 class="font-semibold text-zinc-900"><%= outfit.name %></h2>
              </div>

              <%# description, sous la ligne nom/tags %>
              <p class="text-sm text-zinc-500 line-clamp-2"><%= outfit.description %></p>

              <%# garments, toujours sous la description %>
              <div class="flex flex-wrap gap-2">
                <% outfit.garments.each do |garment| %>
                  <span class="inline-block bg-zinc-100 text-zinc-700 text-xs px-3 py-1 rounded-full"><%= garment.name %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
</section>
