<section class="min-h-screen bg-linear-to-tr from-yellow-900 to-yellow-50 p-4 md:p-8">
  <%# En-tête de page %>
    <div class="flex items-center justify-between mb-8">
      <h1 class="order-first text-3xl md:text-4xl font-bold text-champagne text-shadow-lg/30">My Outfits</h1>
      <div class="flex flex-row-reverse gap-4">
      <%= link_to "Create an outfit", new_outfit_path, class: "bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition" %>
      <%= link_to "My clothes", garments_path, class: "bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition" %>
      </div>
    </div>

    <% if @outfits.empty? %>

      <%#  Etat vide %>
      <div class="text-center py-20">
        <p class="text-lg text-zinc-800 mb-4">You haven't added any outfits yet.</p>
        <%= link_to "Create your first outfit", new_outfit_path, class: "inline-block bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 hover:text-white transition" %>
      </div>
      <% else %>

      <%# Grille de cards %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @outfits.each do |outfit| %>
          <%= link_to outfit, class: "block bg-white rounded-xl shadow-xl overflow-hidden relative transition duration-300 ease-out hover:scale-105 hover:shadow-2xl hover:z-10" do %>
            <div class="h-48 bg-zinc-100 flex items-center justify-center">
              <span class="text-sm text-zinc-400">Photo</span>
            </div>
            <div class="p-4 flex items-start justify-between gap-2">
              <div class="flex flex-col items-start gap-2">
                <h2 class="font-semibold text-zinc-900"><%= outfit.name %></h2>
                <p class="text-sm text-zinc-500 mt-1 line-clamp-2"><%= outfit.description %></p>
              </div>
              <div class="rounded-xl bg-zinc-200 p-1">
                <h2>tags</h2>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
</section>
