<%= form_with model: outfit do |f| %>

  <div class="mb-4">
    <%= f.label :name, class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :name, class: "block w-full rounded-md border border-zinc-300 px-3 py-2 text-zinc-900 shadow-sm focus:border-zinc-500 focus:ring-2 focus:ring-zinc-500 focus:outline-none" %>
    <% if outfit.errors[:name].any? %>
      <span class="block text-sm text-red-600 mt-1"><%= outfit.errors[:name].first %></span>
    <% end %>
  </div>

  <div class="mb-4">
    <%= f.label :description, class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_area :description, class: "block w-full rounded-md border border-zinc-300 px-3 py-2 text-zinc-900 shadow-sm focus:border-zinc-500 focus:ring-2 focus:ring-zinc-500 focus:outline-none" %>
  </div>

  <div class="mb-4" data-controller="garment-select">
    <%= f.label :garment_ids, "Pieces", class: "block text-sm font-medium text-zinc-700 mb-1" %>

    <div data-garment-select-target="board" class="mb-3 grid grid-cols-3 gap-2 md:grid-cols-4"></div>

    <%= f.select :garment_ids,
          options_for_select(
            @garments.map { |garment| [garment.name, garment.id, { "data-thumb": garment_thumb_url(garment) }] },
            outfit.garment_ids
          ),
          { include_blank: false },
          { multiple: true, data: { "garment-select-target": "select" } } %>
    <% if outfit.errors[:garments].any? %>
      <span class="block text-sm text-red-600 mt-1"><%= outfit.errors[:garments].first %></span>
    <% end %>

  </div>

  <div class="mb-4">
    <%= f.label :tag_names, "Tags", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :tag_names, placeholder: "casual, summer, blue", class: "block w-full rounded-md border border-zinc-300 px-3 py-2 text-zinc-900 shadow-sm focus:border-zinc-500 focus:ring-2 focus:ring-zinc-500 focus:outline-none" %>
    <p class="mt-1 text-sm text-zinc-500">Split the tags with comas</p>
  </div>

  <div class="mb-4">
    <span class="block text-sm font-medium text-zinc-700 mb-1">Visibility</span>
    <div class="flex gap-2">
      <label class="flex-1">
        <%= f.radio_button :visibility, "private", class: "peer sr-only" %>
        <span class="block text-center py-2 px-3 rounded-md border border-zinc-300 cursor-pointer peer-checked:bg-zinc-900 peer-checked:text-champagne">
          Private
        </span>
      </label>
      <label class="flex-1">
        <%= f.radio_button :visibility, "public", class: "peer sr-only" %>
        <span class="block text-center py-2 px-3 rounded-md border border-zinc-300 cursor-pointer peer-checked:bg-zinc-900 peer-checked:text-champagne">
          Public
        </span>
      </label>
    </div>
  </div>

  <div>
    <%= f.submit class: "w-full bg-zinc-900 text-champagne font-semibold py-2 px-5 rounded-md hover:bg-zinc-700 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:text-white hover:text-white" %>
  </div>
<% end %>
