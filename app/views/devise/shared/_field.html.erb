<% label = local_assigns.fetch(:label, attribute.to_s.humanize) %>
<% options = local_assigns.fetch(:options, {}) %>

<div class="flex flex-col gap-1">
  <%= form.label attribute, label, class: "text-caption font-medium text-zinc-700" %>
  <%= form.send("{type}_field", attribute, options.merge(class: "w-full rounded-lg border border-zinc-300 px-3 py-2 focus:outline-none focus:ring-zinc-900/20")) %>
</div>
