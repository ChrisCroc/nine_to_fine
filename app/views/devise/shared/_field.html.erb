<% label = local_assigns.fetch(:label, attribute.to_s.humanize) %>
<% options = local_assigns.fetch(:options, {}) %>
<% errors = form.object.errors[attribute] %>
<% input_classes = "w-full rounded-lg border #{errors.any? ? "border-red-400" : "border-zinc-300"} bg-white px-3 py-2 shadow-sm focus:outline-none focus:ring-zinc-900/20" %>

<div class="flex flex-col gap-1">
  <%= form.label attribute, label, class: "text-caption font-medium text-zinc-700" %>
  <% if type == :password %>
    <div class="relative" data-controller="password-visibility">
      <%= form.password_field attribute, options.merge(class: "#{input_classes} pr-10", data: { password_visibility_target: "input" }) %>
      <button type="button" data-action="password-visibility#toggle" aria-label="Show password" class="absolute inset-y-0 right-0 flex items-center px-3 text-zinc-500 hover:text-zinc-700">
        <i class="fa-solid fa-eye" data-password-visibility-target="icon"></i>
      </button>
    </div>
  <% else %>
    <%= form.send("#{type}_field", attribute, options.merge(class: input_classes)) %>
  <% end %>
  <% errors.each do |message| %>
    <p class="text-caption text-red-600"><%= message %></p>
  <% end %>
</div>
